{%- comment -%}
  Stacked lockup — three-line TITLE / CARD / TEES. Square formats.
{%- endcomment -%}
{%- assign logo_size = size | default: 180 -%}
<svg viewBox="0 0 280 240" xmlns="http://www.w3.org/2000/svg" style="width: {{ logo_size }}px;" role="img" aria-label="{{ shop.name }}">
  <text x="140" y="75" text-anchor="middle" font-family="Archivo Black, sans-serif" font-size="48" fill="#151419" letter-spacing="-1">TITLE</text>
  <text x="140" y="130" text-anchor="middle" font-family="Archivo Black, sans-serif" font-size="48" fill="#151419" letter-spacing="-1">CARD</text>
  <text x="140" y="185" text-anchor="middle" font-family="Archivo Black, sans-serif" font-size="48" fill="#151419" letter-spacing="-1">TEES</text>
  <path d="M50 210 Q75 198, 100 210 T150 210 T200 210 T230 210" stroke="#E8743C" stroke-width="5" fill="none" stroke-linecap="round"/>
</svg>
