<style>
  .cart-overlay {
    position: fixed; inset: 0;
    background: rgba(21, 20, 25, 0.5);
    opacity: 0; pointer-events: none;
    transition: opacity 0.25s ease;
    z-index: 90;
  }
  .cart-overlay.is-open { opacity: 1; pointer-events: auto; }

  .cart-drawer {
    position: fixed; top: 0; right: 0;
    height: 100vh; width: 100%; max-width: 460px;
    background: var(--cream);
    border-left: 2px solid var(--ink);
    transform: translateX(100%);
    transition: transform 0.32s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 100;
    display: flex; flex-direction: column;
  }
  .cart-drawer.is-open { transform: translateX(0); }

  .cart-drawer-head {
    padding: 22px 28px;
    border-bottom: 2px solid var(--ink);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .cart-drawer-head h2 {
    font-family: 'Unbounded', sans-serif;
    font-size: 22px;
    font-weight: 800;
    letter-spacing: -0.02em;
  }
  .cart-drawer-close {
    font-family: 'Archivo Black', sans-serif;
    font-size: 11px;
    letter-spacing: 0.18em;
    padding: 8px 14px;
    border: 1.5px solid var(--ink);
    border-radius: 100px;
  }
  .cart-drawer-close:hover { background: var(--ink); color: var(--cream); }

  .cart-drawer-body {
    flex: 1;
    overflow-y: auto;
    padding: 0;
  }
  .cart-line {
    display: grid;
    grid-template-columns: 72px 1fr auto;
    gap: 16px;
    padding: 20px 28px;
    border-bottom: 1px solid rgba(21,20,25,0.12);
    align-items: flex-start;
  }
  .cart-line-thumb {
    aspect-ratio: 1;
    background: var(--cream-deep);
    border: 1.5px solid var(--ink);
    overflow: hidden;
  }
  .cart-line-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .cart-line-title {
    font-family: 'Unbounded', sans-serif;
    font-size: 15px;
    font-weight: 800;
    letter-spacing: -0.01em;
    margin-bottom: 4px;
  }
  .cart-line-variant {
    font-size: 12px;
    opacity: 0.65;
    margin-bottom: 10px;
  }
  .cart-line-qty {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
  }
  .cart-line-qty input {
    width: 48px;
    padding: 4px 8px;
    border: 1.5px solid var(--ink);
    background: var(--cream);
    border-radius: 100px;
    text-align: center;
    font-size: 13px;
    font-family: inherit;
  }
  .cart-line-remove {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: underline;
    opacity: 0.7;
  }
  .cart-line-price {
    font-family: 'Archivo Black', sans-serif;
    font-size: 15px;
    text-align: right;
  }

  .cart-empty {
    padding: 80px 28px;
    text-align: center;
  }
  .cart-empty h3 {
    font-family: 'Unbounded', sans-serif;
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 10px;
  }
  .cart-empty p {
    opacity: 0.7;
    margin-bottom: 28px;
  }

  .cart-drawer-foot {
    border-top: 2px solid var(--ink);
    padding: 22px 28px 28px;
    background: var(--cream-deep);
  }
  .cart-drawer-foot .subtotal-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }
  .cart-drawer-foot .subtotal-row .label {
    font-family: 'Archivo Black', sans-serif;
    font-size: 12px;
    letter-spacing: 0.18em;
  }
  .cart-drawer-foot .subtotal-row .value {
    font-family: 'Archivo Black', sans-serif;
    font-size: 22px;
  }
  .cart-drawer-foot .note {
    font-size: 12px;
    opacity: 0.6;
    margin-bottom: 20px;
  }
  .cart-drawer-foot button.btn-primary { width: 100%; justify-content: center; }
</style>

<div class="cart-overlay" data-cart-overlay aria-hidden="true"></div>
<aside class="cart-drawer"
       data-cart-drawer
       aria-hidden="true"
       aria-label="{{ 'cart.general.title' | t }}">
  <div class="cart-drawer-head">
    <h2>{{ 'cart.general.title' | t }}</h2>
    <button class="cart-drawer-close" data-cart-close>Close</button>
  </div>
  <div class="cart-drawer-body" data-cart-drawer-contents>
    {% render 'cart-drawer-contents', cart: cart %}
  </div>
</aside>
