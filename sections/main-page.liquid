<style>
  .page { padding: 80px 0 120px; }
  .page-head {
    max-width: 780px;
    margin: 0 auto 60px;
    text-align: left;
  }
  .page-head .eyebrow {
    font-family: 'Archivo Black', sans-serif;
    font-size: 11px;
    letter-spacing: 0.22em;
    margin-bottom: 20px;
    display: inline-flex; align-items: center; gap: 10px;
  }
  .page-head .eyebrow::before {
    content:''; width:8px; height:8px; border-radius:50%; background:var(--tangerine);
  }
  .page-head h1 {
    font-family: 'Unbounded', sans-serif;
    font-size: clamp(48px, 6vw, 82px);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 0.95;
  }
  .page-head h1 .ital { font-family:'Fraunces',serif; font-style:italic; font-weight:400; }
  .page-body {
    max-width: 780px;
    margin: 0 auto;
    font-size: 18px;
    line-height: 1.7;
  }
  .page-body h2 {
    font-family: 'Unbounded', sans-serif;
    font-size: 32px;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 48px 0 16px;
  }
  .page-body h3 {
    font-family: 'Archivo Black', sans-serif;
    font-size: 15px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 36px 0 10px;
  }
  .page-body p { margin-bottom: 20px; }
  .page-body ul, .page-body ol { margin: 0 0 20px 22px; }
  .page-body li { margin-bottom: 8px; }
  .page-body a { text-decoration: underline; text-decoration-color: var(--tangerine); text-underline-offset: 4px; }
</style>

<section class="page">
  <div class="container">
    <div class="page-head">
      <div class="eyebrow">{{ page.template_suffix | default: 'Page' | upcase }}</div>
      <h1>{{ page.title }}</h1>
    </div>
    <div class="page-body rte">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{ "name": "Page", "settings": [] }
{% endschema %}
