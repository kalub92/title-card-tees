<style>
  .collection {
    padding: 110px 0 120px;
    border-bottom: 2px solid var(--ink);
  }
  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .product {
    border: 2px solid var(--ink);
    background: var(--cream);
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  .product:hover { transform: translateY(-6px); }
  .product-slot {
    font-family: 'Archivo Black', sans-serif;
    font-size: 11px;
    letter-spacing: 0.15em;
    padding: 12px 18px;
    background: var(--cream-deep);
    border-bottom: 1.5px solid var(--ink);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .product-slot .slot-time { color: var(--tangerine); }
  .product-slot .run {
    opacity: 0.55;
    font-weight: 400;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.1em;
  }
  .product-card {
    aspect-ratio: 4 / 5;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px;
    position: relative;
    overflow: hidden;
  }
  .product-card.card-mustard { background: var(--mustard); }
  .product-card.card-teal { background: var(--teal); }
  .product-card.card-rose { background: var(--rose); }
  .product-card.card-ink { background: var(--ink); }
  .product-card.card-tangerine { background: var(--tangerine); }
  .product-card.card-cream { background: var(--cream-deep); }
  .product-card-placeholder { width: 100%; }
  .product-card img { width: 100%; height: 100%; object-fit: contain; }
  .product-info {
    padding: 22px 22px 24px;
    border-top: 1.5px solid var(--ink);
    background: var(--cream);
  }
  .product-info .name {
    font-family: 'Unbounded', sans-serif;
    font-size: 22px;
    font-weight: 800;
    letter-spacing: -0.015em;
    margin-bottom: 6px;
  }
  .product-info .desc {
    font-size: 13px;
    line-height: 1.5;
    opacity: 0.75;
    margin-bottom: 18px;
  }
  .product-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .price {
    font-family: 'Archivo Black', sans-serif;
    font-size: 20px;
    letter-spacing: -0.005em;
  }
  .quick-shop {
    font-family: 'Archivo Black', sans-serif;
    font-size: 11px;
    letter-spacing: 0.15em;
    padding: 10px 16px;
    border: 1.5px solid var(--ink);
    border-radius: 100px;
    transition: all 0.2s;
    display: inline-block;
  }
  .quick-shop:hover { background: var(--ink); color: var(--cream); }
  .product.sold-out .product-card::after {
    content: 'SOLD OUT';
    position: absolute;
    inset: 0;
    background: rgba(21, 20, 25, 0.82);
    color: var(--cream);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Archivo Black', sans-serif;
    font-size: 20px;
    letter-spacing: 0.3em;
  }
  @media (max-width: 900px) {
    .collection { padding: 70px 0 80px; }
    .product-grid { grid-template-columns: 1fr; gap: 20px; }
  }
</style>

{%- assign drop_handle = section.settings.collection.handle | default: settings.current_drop.handle -%}
{%- if section.settings.collection != blank -%}
  {%- assign drop = section.settings.collection -%}
{%- elsif settings.current_drop != blank -%}
  {%- assign drop = settings.current_drop -%}
{%- endif -%}

{%- assign products = drop.products -%}
{%- assign total = products.size -%}

{%- assign all_sold = true -%}
{%- for p in products -%}
  {%- if p.available -%}{%- assign all_sold = false -%}{%- endif -%}
{%- endfor -%}

<section class="collection" id="drop">
  <div class="container">
    <div class="section-head">
      <div>
        <div class="label">{{ section.settings.label | default: 'Now Airing · Drop 01' }}</div>
        <h2>
          {{ section.settings.title_lead | default: 'The Saturday' }}<br/>
          {{ section.settings.title_middle | default: 'Morning' }}
          {%- if section.settings.title_italic != blank %} <span class="ital">{{ section.settings.title_italic }}</span>{% endif -%}
        </h2>
      </div>
      <div class="meta">
        <div class="counter">{{ total }} PIECES · {{ section.settings.run_per_piece | default: 250 }} EACH</div>
        <p>{{ section.settings.meta_copy }}</p>
      </div>
    </div>

    {%- if products.size > 0 -%}
      <div class="product-grid">
        {% for product in products %}
          {%- capture forloop_str -%}0{{ forloop.index }}{%- endcapture -%}
          {%- assign pos = forloop_str | slice: -2, 2 -%}
          {%- capture total_str -%}0{{ total }}{%- endcapture -%}
          {%- assign total_padded = total_str | slice: -2, 2 -%}
          <article class="product {% unless product.available %}sold-out{% endunless %}" data-product-handle="{{ product.handle }}">
            <div class="product-slot">
              <span class="slot-time">{{ product.metafields.tct.slot_time | default: '—' }}</span>
              <span class="run">{{ product.metafields.tct.run_position | default: pos }} / {{ total_padded }} · {{ product.metafields.tct.run_size | default: 250 }} MADE</span>
            </div>
            {%- assign card_color = product.metafields.tct.card_color | default: 'cream' | downcase -%}
            <a class="product-card card-{{ card_color }}" href="{{ product.url }}" aria-label="{{ product.title }}">
              {%- if product.metafields.tct.title_card_svg != blank -%}
                {{ product.metafields.tct.title_card_svg }}
              {%- elsif product.featured_image != blank -%}
                <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | default: product.title }}" loading="lazy" width="600" height="750">
              {%- else -%}
                <div class="product-card-placeholder" aria-hidden="true">
                  <svg viewBox="0 0 280 280" xmlns="http://www.w3.org/2000/svg" style="width: 100%;">
                    <rect x="40" y="95" width="200" height="85" rx="10" fill="#151419"/>
                    <text x="140" y="148" text-anchor="middle" font-family="Archivo Black, sans-serif" font-size="26" fill="#F4EDE0">{{ product.title | upcase }}</text>
                  </svg>
                </div>
              {%- endif -%}
            </a>
            <div class="product-info">
              <div class="name">{{ product.title }}</div>
              <div class="desc">{{ product.metafields.tct.short_desc | default: product.description | strip_html | truncatewords: 16 }}</div>
              <div class="product-row">
                <span class="price">{{ product.price | money_without_trailing_zeros }}</span>
                {%- if product.available -%}
                  <a href="{{ product.url }}" class="quick-shop">ADD TO BAG</a>
                {%- else -%}
                  <a href="{{ product.url }}" class="quick-shop">NOTIFY WHEN BACK</a>
                {%- endif -%}
              </div>
            </div>
          </article>
        {% endfor %}
      </div>
    {%- else -%}
      <p class="meta-text">No drop configured. Set the current drop in theme settings.</p>
    {%- endif -%}

    {%- if all_sold and products.size > 0 -%}
      <p class="meta-text" style="margin-top: 40px; text-align: center;">The drop is off the air. The next one is below.</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Drop grid",
  "tag": "div",
  "class": "drop-grid-section",
  "settings": [
    { "type": "collection", "id": "collection", "label": "Drop collection", "info": "Defaults to the current drop from theme settings." },
    { "type": "text", "id": "label", "label": "Eyebrow label", "default": "Now Airing · Drop 01" },
    { "type": "text", "id": "title_lead", "label": "Headline line 1", "default": "The Saturday" },
    { "type": "text", "id": "title_middle", "label": "Headline line 2", "default": "Morning" },
    { "type": "text", "id": "title_italic", "label": "Italic word", "default": "Drop." },
    { "type": "number", "id": "run_per_piece", "label": "Run per piece", "default": 250 },
    { "type": "textarea", "id": "meta_copy", "label": "Meta copy", "default": "Six title cards for the ritual. Each piece is heavyweight 14 oz cotton, hand-numbered inside the hem tag, limited to 250. When they're gone, they don't come back." }
  ],
  "presets": [
    { "name": "Drop grid" }
  ]
}
{% endschema %}
