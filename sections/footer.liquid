<style>
  footer.site-footer {
    background: var(--ink);
    color: var(--cream);
    padding: 90px 0 34px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 60px;
    margin-bottom: 70px;
    padding-bottom: 50px;
    border-bottom: 1px solid rgba(244,237,224,0.18);
  }
  .footer-brand .big-mono {
    font-family: 'Archivo Black', sans-serif;
    font-size: 72px;
    line-height: 1;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
  }
  .footer-brand p {
    font-size: 15px;
    line-height: 1.5;
    opacity: 0.7;
    max-width: 300px;
  }
  .footer-col h5 {
    font-family: 'Archivo Black', sans-serif;
    font-size: 11px;
    letter-spacing: 0.22em;
    color: var(--tangerine);
    margin-bottom: 22px;
  }
  .footer-col ul { list-style: none; }
  .footer-col li { margin-bottom: 12px; font-size: 15px; }
  .footer-col a { opacity: 0.8; transition: opacity 0.2s; }
  .footer-col a:hover { opacity: 1; }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
    letter-spacing: 0.05em;
    opacity: 0.5;
  }
  @media (max-width: 900px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 40px; margin-bottom: 40px; }
    .footer-brand { grid-column: 1 / 3; }
    .footer-brand .big-mono { font-size: 54px; }
    .footer-bottom { flex-direction: column; gap: 10px; text-align: center; }
  }
</style>

<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="big-mono">{{ section.settings.mark | default: 'TCT.' }}</div>
        <p>{{ section.settings.tagline }}</p>
      </div>

      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'link_column' %}
            <div class="footer-col" {{ block.shopify_attributes }}>
              <h5>{{ block.settings.heading }}</h5>
              <ul>
                {% assign links = block.settings.links | newline_to_br | split: '<br />' %}
                {% for raw in links %}
                  {% assign parts = raw | split: '|' %}
                  {% if parts.size >= 2 %}
                    <li><a href="{{ parts[1] | strip }}">{{ parts[0] | strip }}</a></li>
                  {% endif %}
                {% endfor %}
              </ul>
            </div>
        {% endcase %}
      {% endfor %}
    </div>
    <div class="footer-bottom">
      <div>© {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</div>
      <div>
        <a href="/policies/privacy-policy">Privacy</a> ·
        <a href="/policies/terms-of-service">Terms</a> ·
        <a href="/pages/accessibility">Accessibility</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "div",
  "class": "footer-section",
  "settings": [
    { "type": "text", "id": "mark", "label": "Footer mark", "default": "TCT." },
    { "type": "textarea", "id": "tagline", "label": "Tagline", "default": "Title cards from the shows we love. Title Card Tees, est. 2026." }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Link column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "SHOP" },
        { "type": "textarea", "id": "links", "label": "Links", "info": "One per line: Label | /path", "default": "The current drop | /#drop\nNext drop | /#next\nSizing | /pages/sizing\nReturns | /pages/returns" }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_column",
        "settings": {
          "heading": "SHOP",
          "links": "The current drop | /#drop\nNext drop | /#next\nSizing | /pages/sizing\nReturns | /pages/returns"
        }
      },
      {
        "type": "link_column",
        "settings": {
          "heading": "ABOUT",
          "links": "Our story | /pages/about\nThe fabric | /pages/fabric\nHow we drop | /pages/how-we-drop\nContact | /pages/contact"
        }
      },
      {
        "type": "link_column",
        "settings": {
          "heading": "FOLLOW",
          "links": "Instagram | https://instagram.com\nTikTok | https://tiktok.com\nEmail list | /#next"
        }
      }
    ]
  },
  "enabled_on": { "groups": ["footer"] }
}
{% endschema %}
