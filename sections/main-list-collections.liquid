<section class="collection" style="text-align:center;">
  <div class="container" style="max-width: 640px;">
    <span class="pill" style="margin-bottom:24px;">ONE DROP AT A TIME</span>
    <h1 style="font-family:'Unbounded',sans-serif;font-size:clamp(48px,6vw,72px);font-weight:900;letter-spacing:-0.035em;line-height:0.95;margin-bottom:20px;">
      No archive. <span class="ital">Just the drop.</span>
    </h1>
    <p style="font-size:17px;opacity:0.7;max-width:460px;margin:0 auto 36px;">
      Only the current drop is on the air. Past drops are retired — the archive lives in the closets of the people who caught them.
    </p>
    <a href="{{ routes.root_url }}#drop" class="btn-primary">TO THE CURRENT DROP <span class="arrow">→</span></a>
  </div>
</section>

{% schema %}
{ "name": "Collection list", "settings": [] }
{% endschema %}
